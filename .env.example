# Supabase
NEXT_PUBLIC_SUPABASE_URL=your-supabase-url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key
# Service-role key (server-side only — never expose to client)
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key

# App host (used by /api/agent/session to build fully-qualified URLs on Vercel SSR
# where the origin request header may be absent)
NEXT_PUBLIC_APP_HOST=https://your-app.vercel.app

# Rate limiting
# DISABLE_RATE_LIMIT=false
# Set to true ONLY in E2E test environments to bypass the rate limiter.
# Never set to true in production — this removes all request throttling.
# DISABLE_RATE_LIMIT=true

# API Key Auth (optional)
# When set, all /api/projects/* requests must include:
#   - Header: x-api-key: <value>  OR  query param: ?apiKey=<value>
# Leave unset (or empty) to allow all requests in dev mode.
# API_KEY=your-secret-key-here
