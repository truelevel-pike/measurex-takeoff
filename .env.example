# ─────────────────────────────────────────────────────────────────────────────
# MeasureX — Environment Variables
# Copy this file to .env.local and fill in your values.
#   cp .env.example .env.local
# ─────────────────────────────────────────────────────────────────────────────

# ── AI: Google Gemini (REQUIRED for AI Takeoff) ──────────────────────────────
# Get your key at: https://aistudio.google.com/app/apikey
# Used by: AI Takeoff (single-page + all-pages), scale auto-detection
GOOGLE_API_KEY=your-google-api-key-here

# ── AI: OpenAI (optional — enables GPT-4o / o4-mini models) ─────────────────
# Get your key at: https://platform.openai.com/api-keys
# Used by: AI Takeoff when model=gpt-4o / gpt-4.1 / o4-mini is selected
OPENAI_API_KEY=

# ── AI: OpenRouter (optional — fallback router for multiple providers) ───────
# Get your key at: https://openrouter.ai/keys
# Used by: AI Takeoff when OPENAI_API_KEY is absent and model requires it
OPENROUTER_API_KEY=

# ── App Host (REQUIRED on Vercel for share links + agent session URLs) ───────
# Set to your deployed URL — MUST include https:// — no trailing slash.
# Used by: /api/agent/session (builds fully-qualified URLs), share link generation
# The code normalises missing protocols, but always include it for clarity.
# Example: https://app.measurex.io  or  https://my-project.vercel.app
NEXT_PUBLIC_APP_HOST=https://your-app.vercel.app

# ── Supabase (required for production persistent storage) ────────────────────
# Create a project at: https://supabase.com
# When these are set, MeasureX uses Supabase tables instead of local JSON files.
# Without these, data is stored in ./data/ (local dev only — not persistent on Vercel).
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key
# Service-role key — server-side only, NEVER expose to the browser
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key

# ── API Key Auth (optional — protects /api/projects/* from public access) ────
# When set, all API requests must include:
#   Header:      x-api-key: <value>
#   OR query:    ?apiKey=<value>
# Leave blank to allow unauthenticated access (fine for local dev).
API_KEY=

# ── Admin Secret (optional — protects webhook registration + admin endpoints) ─
# Required header for: POST/DELETE /api/projects/:id/webhooks, /api/metrics, /api/flags
ADMIN_SECRET=

# ── Rate Limiting ─────────────────────────────────────────────────────────────
# ⚠️  SECURITY CRITICAL — read before touching this.
# When true, ALL rate limiting on ALL API endpoints is disabled.
# This includes AI takeoff (expensive), file upload, and share link endpoints.
# Use ONLY in local E2E test runs. NEVER commit true to .env.local if you push.
# NEVER set in production — the build will log a SECURITY WARNING at runtime.
#
# Safe values:
#   (commented out)  — rate limiting is active (default for all envs)
#   =false           — rate limiting is active
#   =true            — rate limiting DISABLED (E2E tests only)
#
# DISABLE_RATE_LIMIT=false
